#!/bin/sh
set -eu

cd -P -- "$(dirname -- "$0")"

# Usage: bin/set-password <email> [password]
# Generates a strong password when none is given (and prints it).
if [ "$#" -lt 1 ]; then
  echo "usage: bin/set-password <email> [password]" >&2
  exit 2
fi

if [ "$#" -ge 2 ]; then
  exec ./feed_pug eval "FeedPug.Release.set_password(\"$1\", \"$2\")"
else
  exec ./feed_pug eval "FeedPug.Release.set_password(\"$1\")"
fi
